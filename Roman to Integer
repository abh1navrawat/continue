class Solution {
    public int romanToInt(String s) {
        Map<Character,Integer> hs=new HashMap<>(Map.of('I',1,'V',5,'X',10,'L',50,'C',100,'D',500,'M',1000));
        int res=0;
        for(int i=0;i<s.length()-1;i++){
            res+=hs.get(s.charAt(i));
            if (((s.charAt(i+1)=='X' || s.charAt(i+1)=='V' )&& s.charAt(i)=='I') ||((s.charAt(i+1)=='L' || s.charAt(i+1)=='C' )&& s.charAt(i)=='X')||((s.charAt(i+1)=='D' || s.charAt(i+1)=='M' )&& s.charAt(i)=='C')){
                res-=2*hs.get(s.charAt(i));
            }
        }
        res+=hs.get(s.charAt(s.length()-1));
        return res;
    }
