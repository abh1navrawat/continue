class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        nums[:] = sorted(list(set(nums)))
        return len(nums)





**java - 2 pointer - if a duplicate comes ignore it whereas if a unique number comes, increment your unique number counter and place it there. As it is a non decreasing array, we will not get the same number
                     again after moving to next unique number.





class Solution {
    public int removeDuplicates(int[] nums) {
        int res=0;
        for (int i=1;i<nums.length;i++){
            if (nums[i]!=nums[res]){
                nums[res+1]=nums[i];
                res++;
            }
        }
        return res+1;
    }
}
