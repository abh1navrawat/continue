You are given an integer array prices where prices[i] is the price of a given stock on the ith day.

On each day, you may decide to buy and/or sell the stock. You can only hold at most one share of the stock at any time. However, you can sell and buy the stock multiple times on the same day, ensuring you never hold more than one share of the stock.

Find and return the maximum profit you can achieve.



intuition - if current stock is smaller then the current purchased stock, make this the purchased stock. If current stock is larger than the purchased stock then their difference will be your profit
            and change the current stock to purchased stock






class Solution:
    def maxProfit(self, prices: List[int]) -> int:
        pro=0
        res=prices[0]
        for i in prices:
            if i<res:
                res=i
            elif res<i:
                pro+=i-res
                res=i
        return pro


java -



class Solution {
    public int maxProfit(int[] prices) {
        int res=0;
        int n=prices.length;
        int curr=Integer.MAX_VALUE;

        for (int i=0;i<n;i++){
            if (curr>prices[i]){
                curr=prices[i];
            }
            else{
                res+=(prices[i]-curr);
                curr=prices[i];
            }
        }
        return res;
    }
}
