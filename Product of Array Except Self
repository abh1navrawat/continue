            Whenever we found a question stating we have to find something (product,sum,etc) we have to make 2 array and go from left to right then right to left(can do vice versa).







class Solution {
    public int[] productExceptSelf(int[] nums) {
        int n=nums.length-1;
        int[] answer=new int[n+1];
        int var=1;
        for(int i=n;i>=0;i--){
            answer[i]=var;
            var*=nums[i];
        }
        var=1;
        for(int i=0;i<=n;i++){
            answer[i]*=var;
            var*=nums[i];
        }
        return answer;
    }
}
