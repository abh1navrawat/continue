class Solution:
    def productExceptSelf(self, nums: List[int]) -> List[int]:
        list1=[1]*(len(nums))
        list2=[1]*(len(nums))
        post,pre=1,1
        for i in range(len(nums)):
            list1[i]=pre
            pre*=nums[i]
        for j in range(len(nums)-1,-1,-1):
            list2[j]=post
            post*=nums[j]
        res=[]
        for k in range(len(nums)):
            res.append(list1[k]*list2[k])
        return res






